TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_MYPKA=5rBRze0O

TRELLO_LIST_TOPICS=
TRELLO_LIST_PROJECTS=
TRELLO_LIST_GOALS=
TRELLO_LIST_CRM=
TRELLO_LIST_INCOMING=

# Optional — the `Journal` list, for real day entries.
# `Incoming` stages into `Team Inbox/` (WS-005 Stream B); this list is the
# direct path to `PKM/Journal/YYYY/MM/` for entries that are already a day
# entry and don't need triage. Leave blank until the Trello list exists —
# the sync runs fine without it.
TRELLO_LIST_JOURNAL=

# Optional — the `Research` list (-> PKM/My Life/Topics with research_status).
TRELLO_LIST_RESEARCH=

PKA_REPO_PATH=/home/ubuntu/PKA

# Optional — repeat-failure guardrail alert (src/guardrail.py + src/notifier.py).
# If left blank, notifier.alert() logs a warning and no-ops instead of failing startup.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
